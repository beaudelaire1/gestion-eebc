# =============================================================================
# CONFIGURATION GESTION EEBC
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================================

# Django
DEBUG=True
SECRET_KEY=votre-cle-secrete-generee-ici
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# CONFIGURATION EMAIL
# =============================================================================

# Backend email (options: smtp, console, file, hostinger)
# - console : affiche les emails dans la console (développement)
# - smtp : envoi réel via serveur SMTP standard (Gmail, Outlook, etc.)
# - hostinger : envoi via l'API email Hostinger (recommandé pour production)
EMAIL_BACKEND=console

# Configuration SMTP standard (Gmail, Outlook, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application

# Configuration Hostinger Email (recommandée)
HOSTINGER_API_KEY=votre-cle-api-hostinger
HOSTINGER_EMAIL_HOST=smtp.hostinger.com
HOSTINGER_EMAIL_PORT=587
HOSTINGER_EMAIL_USE_TLS=True
HOSTINGER_EMAIL_USE_SSL=False
HOSTINGER_EMAIL_HOST_USER=votre-email@votre-domaine.com
HOSTINGER_EMAIL_HOST_PASSWORD=votre-mot-de-passe-email

# Configuration avancée Hostinger
HOSTINGER_EMAIL_TIMEOUT=30
HOSTINGER_EMAIL_MAX_RETRIES=3
HOSTINGER_API_BASE_URL=https://developers.hostinger.com

# Expéditeur par défaut
DEFAULT_FROM_EMAIL=EEBC <noreply@eebc.org>
EMAIL_FROM_NAME=EEBC

# =============================================================================
# CELERY (pour tâches asynchrones)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# BASE DE DONNÉES (optionnel - SQLite par défaut)
# =============================================================================
# DATABASE_URL=postgres://user:password@localhost:5432/eebc_db

# =============================================================================
# STRIPE (Paiements en ligne)
# =============================================================================
# Créez un compte sur https://stripe.com et récupérez vos clés
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# URLs de redirection (adapter selon votre domaine)
STRIPE_SUCCESS_URL=http://localhost:8000/don/succes/
STRIPE_CANCEL_URL=http://localhost:8000/don/annule/

# =============================================================================
# TWILIO (SMS & WhatsApp)
# =============================================================================
# Créez un compte sur https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+594XXXXXXXXX
TWILIO_WHATSAPP_NUMBER=+14155238886

# =============================================================================
# META WHATSAPP CLOUD API (notifications générales et rappels)
# =============================================================================
# Créez une app sur https://developers.facebook.com/
META_WHATSAPP_ACCESS_TOKEN=EAAGxxxxxxxxxxxxxxxxxxxx
META_WHATSAPP_PHONE_NUMBER_ID=123456789012345
META_WHATSAPP_VERIFY_TOKEN=votre-token-webhook
META_WHATSAPP_APP_SECRET=votre-app-secret-meta
META_WHATSAPP_API_VERSION=v23.0

# =============================================================================
# CAPTCHA - CloudFlare Turnstile (recommandé)
# =============================================================================
# Créez un site sur https://dash.cloudflare.com/
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# =============================================================================
# CAPTCHA - Google reCAPTCHA v3 (legacy, dépréciable après migration Turnstile)
# =============================================================================
RECAPTCHA_PUBLIC_KEY=6xxxxxxxxxxxxxxxxxxxx
RECAPTCHA_PRIVATE_KEY=6xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SENTRY (Error Tracking & Monitoring - Optionnel)
# =============================================================================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# =============================================================================
# SESSION & SECURITY
# =============================================================================
SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_SECURE=False  # Mettre à True en PRODUCTION (HTTPS obligatoire)
CSRF_COOKIE_SECURE=False     # Mettre à True en PRODUCTION (HTTPS obligatoire)

# =============================================================================
# CONFIGURATION SITE & ÉGLISE
# =============================================================================
SITE_URL=http://localhost:8000
SITE_NAME=EEBC
SITE_DESCRIPTION=Église Évangélique Baptiste de Cabassou

# Informations légales/église
CHURCH_SIRET=12345678901234
CHURCH_RNA=W123456789
CHURCH_PHONE=+594 (0) 594 XX XX XX
CHURCH_EMAIL=contact@eglise-ebc.org

# Open Graph & Meta tags pour partage social
META_DESCRIPTION=Église Évangélique Baptiste de Cabassou - Guyane
OG_IMAGE_URL=http://localhost:8000/static/img/og-image.png

# Réseaux sociaux
FACEBOOK_URL=https://facebook.com/egliseebc
YOUTUBE_URL=https://youtube.com/@egliseebc
INSTAGRAM_URL=https://instagram.com/egliseebc

# =============================================================================
# CONFIGURATION MÉTIER
# =============================================================================
# Visites pastorales
MEMBER_VISIT_THRESHOLD_DAYS=180  # 6 mois

# Gestion des groupes
RECURRING_ABSENCE_THRESHOLD=3
ROLE_ASSIGNMENT_EXPIRY_HOURS=48

# Notifications par défaut
DEFAULT_NOTIFICATION_DAYS_BEFORE=4
DEFAULT_NOTIFICATION_DAY=3  # 0=Lundi, 3=Jeudi, etc.

# Pagination
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# Limites financières
MAX_FINANCIAL_AMOUNT=1000000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# CACHE REDIS (Pour statistiques dashboard, sessions, etc.)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# BACKUP & INFRASTRUCTURE
# =============================================================================
# Pour le script backup_database.sh
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# AWS S3 (optionnel - pour uploads de backups)
AWS_S3_BUCKET=votre-bucket-nom
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_REGION=us-east-1

# =============================================================================
# DÉVELOPPEMENT UNIQUEMENT
# =============================================================================
# Django Debug Toolbar (développement uniquement)
DEBUG_TOOLBAR=False

# Niveau de logging
LOGGING_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

